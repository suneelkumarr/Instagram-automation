# ================================================
# RsuShop.com - Environment Configuration
# ================================================
# Copy this file to .env and fill in your values

# Environment
NODE_ENV=development
PORT=3001

# URLs
API_URL=http://localhost:3001
WEBHOOK_BASE_URL=https://api.rsushop.com
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rsushop

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT & Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ENCRYPTION_SECRET=32-character-encryption-key-here

# CORS
CORS_ORIGIN=http://localhost:3000

# Meta / Instagram Graph API
# Create app at: https://developers.facebook.com
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
WEBHOOK_VERIFY_TOKEN=your-random-webhook-verify-token

# OpenAI
# Get API key at: https://platform.openai.com
OPENAI_API_KEY=sk-your-openai-api-key

# Stripe
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Stripe Price IDs (create these in your Stripe Dashboard)
STRIPE_PRICE_STARTER=price_starter_monthly
STRIPE_PRICE_PRO=price_pro_monthly
STRIPE_PRICE_AGENCY=price_agency_monthly

# Email (Resend - optional)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@rsushop.com

# Analytics (Plausible - optional)
PLAUSIBLE_URL=https://plausible.io
PLAUSIBLE_API_KEY=

# Monitoring (Sentry - optional)
SENTRY_DSN=
